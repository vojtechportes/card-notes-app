{
  "name": "notestack",
  "version": "1.1.5",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "electron"
  ],
  "scripts": {
    "build": "npm run build --workspace backend && npm run build --workspace frontend && npm run build --workspace electron",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "build:electron": "npm run build --workspace electron",
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:electron": "npm run dev --workspace electron",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "sync:api": "npm run sync:api --workspace frontend",
    "version:patch": "node scripts/update-package-version.mjs --patch",
    "version:minor": "node scripts/update-package-version.mjs --minor",
    "version:major": "node scripts/update-package-version.mjs --major",
    "package": "npm run build && npm run package:electron",
    "package:electron": "npm run package --workspace electron",
    "package:electron:release": "npm run package:release --workspace electron",
    "package:release": "npm run build && npm run package:electron:release",
    "package:dir": "npm run build && npm run package:dir --workspace electron"
  },
  "engines": {
    "node": ">=22"
  }
}
