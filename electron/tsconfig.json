{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noFallthroughCasesInSwitch": true,
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.cts"],
  "exclude": ["dist", "node_modules"]
}
