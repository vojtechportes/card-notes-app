{
  "appId": "com.cardnotes.app",
  "productName": "NoteStack",
  "artifactName": "notestack-${version}-setup.${ext}",
  "directories": {
    "output": "release"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "vojtechportes",
      "repo": "card-notes-app",
      "releaseType": "release"
    }
  ],
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": ".backend-runtime",
      "to": "backend"
    },
    {
      "from": "../frontend/dist",
      "to": "frontend/dist"
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
