{
  "appId": "com.cardnotes.app",
  "productName": "NoteStack",
  "artifactName": "notestack-${version}-setup.${ext}",
  "directories": {
    "output": "release"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "vojtechportes",
      "repo": "card-notes-app",
      "releaseType": "release"
    }
  ],
  "files": ["dist/**/*", "package.json"],
  "npmRebuild": false,
  "extraResources": [
    {
      "from": ".backend-runtime/dist",
      "to": "backend/dist"
    },
    {
      "from": ".backend-runtime/node_modules",
      "to": "backend/node_modules",
      "filter": ["**/*"]
    },
    {
      "from": ".backend-runtime/package.json",
      "to": "backend/package.json"
    },
    {
      "from": ".backend-runtime/runtime-metadata.json",
      "to": "backend/runtime-metadata.json"
    },
    {
      "from": "../frontend/dist",
      "to": "frontend/dist"
    }
  ],
  "afterPack": "scripts/write-app-update-publisher.mjs",
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
